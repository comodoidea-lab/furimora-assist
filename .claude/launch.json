{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vercel Dev (full stack)",
      "runtimeExecutable": "vercel",
      "runtimeArgs": ["dev", "--listen", "3000"],
      "port": 3000
    },
    {
      "name": "Static server (public/)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "public"],
      "port": 3001,
      "autoPort": true
    }
  ]
}
