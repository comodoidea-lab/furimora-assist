{
  "manifest_version": 3,
  "name": "フリモーラ アシスト",
  "short_name": "フリモーラ",
  "version": "1.0.0",
  "description": "メルカリの商品ページにクローン・値下げボタンを追加します",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "フリモーラ アシスト"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jp.mercari.com/item/*",
        "https://jp.mercari.com/sell/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "downloads",
    "clipboardWrite",
    "notifications"
  ],
  "host_permissions": [
    "https://jp.mercari.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://jp.mercari.com/*"]
    }
  ]
}
